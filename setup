#!/bin/bash

# ==============================
#  Termux Environment Setup
# ==============================

set -e  # Exit on error

RED="\e[1;31m"
GREEN="\e[1;32m"
YELLOW="\e[1;33m"
CYAN="\e[1;36m"
RESET="\e[0m"

clear

banner() {
    echo -e "${CYAN}"
    echo "======================================"
    echo "   Setting Up Required Environment"
    echo "======================================"
    echo -e "${RESET}"
}

log() {
    echo -e "${GREEN}[+] $1${RESET}"
}

warn() {
    echo -e "${YELLOW}[!] $1${RESET}"
}

error() {
    echo -e "${RED}[-] $1${RESET}"
    exit 1
}

sleep 1
banner
sleep 1

# ==============================
# Update System
# ==============================

log "Updating system packages..."
apt update -y && apt upgrade -y

# ==============================
# Install Required Packages
# ==============================

PACKAGES=(
    python
    python2
    git
    wget
    tor
    lolcat
)

log "Installing required packages..."
for pkg in "${PACKAGES[@]}"; do
    if ! command -v "$pkg" &>/dev/null; then
        log "Installing $pkg..."
        apt install -y "$pkg"
    else
        warn "$pkg already installed"
    fi
done

# ==============================
# Python & Pip Setup
# ==============================

log "Upgrading pip..."
python3 -m pip install --upgrade pip setuptools wheel

log "Installing Python dependencies..."
pip3 install --upgrade \
    requests \
    requests[socks] \
    stem \
    instagram-py \
    lolcat

# ==============================
# Download Config File
# ==============================

CONFIG_URL="https://git.io/v5DGy"
CONFIG_PATH="$HOME/instapy-config.json"

if [[ ! -f "$CONFIG_PATH" ]]; then
    log "Downloading instapy config..."
    wget -q -O "$CONFIG_PATH" "$CONFIG_URL"
else
    warn "Config file already exists"
fi

# ==============================
# Tor Configuration
# ==============================

TOR_DIR="/data/data/com.termux/files/usr/etc/tor"
PROJECT_DIR="$HOME/venom-instagram-bruteforce"

if [[ -d "$PROJECT_DIR" && -f "$PROJECT_DIR/torrc" ]]; then
    log "Applying Tor configuration..."
    rm -f "$TOR_DIR/torrc"
    cp "$PROJECT_DIR/torrc" "$TOR_DIR/torrc"
else
    warn "torrc not found in project directory"
fi

# ==============================
# Start Tor Service
# ==============================

log "Starting Tor service..."
tor &

sleep 2
log "Setup completed successfully 🎉"


#else
#cd /data/data/com.termux/files/home/venom-instagram-bruteforce
#cp -r torrc /data/data/com.termux/files/usr/etc/tor
